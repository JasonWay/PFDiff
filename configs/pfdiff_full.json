{
  "seed": 42,
  "data": {
    "root": "data/StateHaze1K",
    "val_ratio": 0.1,
    "image_size": 256,
    "num_workers": 4,
    "eval_split": "test"
  },
  "experiment": {
    "name": "pfdiff_full",
    "output_dir": "experiments/pfdiff_full",
    "result_dir": "results/pfdiff_full"
  },
  "model": {
    "variant": "full",
    "base_channels": 32,
    "diffusion_steps": 100,
    "sampling_steps": 10,
    "residual_scale": 1.0,
    "sampling_start": "zeros",
    "use_adaptive_residual": true,
    "use_physics": true,
    "use_frequency": true,
    "use_diffusion": true
  },
  "training": {
    "epochs": 200,
    "batch_size": 24,
    "learning_rate": 0.0001,
    "weight_decay": 0.000001,
    "amp": true,
    "save_every": 1,
    "save_best_by": "psnr",
    "auto_resume": true
  },
  "loss": {
    "l1": 1.0,
    "mse": 0.2,
    "ssim": 0.05,
    "frequency": 0.05,
    "diffusion": 0.05,
    "residual_x0": 0.1,
    "final": 0.2
  }
}
